# App URL / Auth
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_ENVIRONMENT="development"
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"
NEXT_PUBLIC_SENTRY_PROFILES_SAMPLE_RATE="0"
NEXTAUTH_URL="http://localhost:3000"
# Generate: `openssl rand -base64 32`
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"
RECRUITER_EMAILS="admin@example.com"

# Database (Supabase/Postgres)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:6543/postgres?pgbouncer=false"

# Cloudinary
CLOUDINARY_CLOUD_NAME="replace-with-cloud-name"
CLOUDINARY_API_KEY="replace-with-api-key"
CLOUDINARY_API_SECRET="replace-with-api-secret"

# ML Service
ML_SERVICE_URL="http://127.0.0.1:8000"
# Keep these values identical in local dev to avoid 401 Unauthorized:
ML_SERVICE_API_KEY="replace-with-shared-local-key"
FASTAPI_API_KEY="replace-with-shared-local-key"
MONITORING_API_KEY="replace-with-monitoring-key"
MONITORING_BACKEND_URL="http://127.0.0.1:8000"
MONITORING_BACKEND_API_KEY="replace-with-monitoring-key"
PERFORMANCE_WARN_MS="1200"
DATA_DIR="data"

# Sentry (server/build + backend)
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE="0.1"
SENTRY_PROFILES_SAMPLE_RATE="0"
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
